generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


enum UserRole {
  PLATFORM_ADMIN
  RESTAURANT_MANAGER
}

enum RestaurantStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  PILOT
  STARTER
  GROWTH
  PRO
  EXPIRED
}

enum TableStatus {
  EMPTY
  ACTIVE_ORDER
  PREPARING
  SERVED
  BILL_REQUESTED
  PAID
  INACTIVE
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  SERVED
  BILL_REQUESTED
  PAID
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIAL
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  JAZZCASH
  EASYPAISA
  BANK_TRANSFER
  OTHER
}

enum OrderSource {
  ONLINE_QR
  ONLINE_QR_CUSTOMER
  WAITER_ASSISTED_QR
  MANUAL_DASHBOARD
  WAITER_ENTRY
}

enum WaiterRequestType {
  CALL_WAITER
  BILL_REQUEST
  WATER_REQUEST
  CLEAN_TABLE
}

enum RequestStatus {
  PENDING
  RESOLVED
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
}

enum InvoiceStatus {
  DRAFT
  DUE
  PAID
  OVERDUE
  WAIVED
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         UserRole
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  phone        String?
  recoveryEmail String?
  recoveryPhone String?
  isActive     Boolean     @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  activityLogs ActivityLog[]
  adminPasswordResetOtps AdminPasswordResetOtp[]

  @@index([restaurantId])
}

model Restaurant {
  id                   String             @id @default(cuid())
  name                 String
  slug                 String             @unique
  branchName           String
  city                 String
  address              String
  phone                String
  logoUrl              String?
  status               RestaurantStatus   @default(ACTIVE)
  subscriptionStatus   SubscriptionStatus @default(PILOT)
  pilotStartDate       DateTime?
  pilotEndDate         DateTime?
  orderingEnabled      Boolean            @default(true)
  serviceChargePercent Decimal            @default(0) @db.Decimal(8, 2)
  taxPercent           Decimal            @default(0) @db.Decimal(8, 2)
  customerCancelWindowMinutes Int          @default(3)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  users                User[]
  tables               RestaurantTable[]
  categories           Category[]
  menuItems            MenuItem[]
  orders               Order[]
  waiterRequests       WaiterRequest[]
  feedback             Feedback[]
  subscriptions        Subscription[]
  billingInvoices      BillingInvoice[]
  billingPaymentAccounts BillingPaymentAccount[]
  publicOrderAttempts  PublicOrderAttempt[]
  activityLogs         ActivityLog[]
}

model RestaurantTable {
  id           String        @id @default(cuid())
  restaurantId String
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableNumber  Int
  qrUrl        String
  status       TableStatus   @default(EMPTY)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  orders       Order[]
  requests     WaiterRequest[]
  feedback     Feedback[]

  @@unique([restaurantId, tableNumber])
  @@index([restaurantId])
  @@index([tableNumber])
}

model Category {
  id           String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  imageUrl     String?
  sortOrder    Int         @default(0)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  menuItems    MenuItem[]

  @@index([restaurantId])
}

model MenuItem {
  id            String      @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  name          String
  description   String
  price         Decimal     @db.Decimal(10, 2)
  imageUrl      String?
  isAvailable   Boolean     @default(true)
  isActive      Boolean     @default(true)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]

  @@index([restaurantId])
  @@index([categoryId])
}

model Order {
  id                String        @id @default(cuid())
  restaurantId      String
  restaurant        Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId           String
  table             RestaurantTable @relation(fields: [tableId], references: [id])
  orderNumber       String
  customerSessionId String?
  source            OrderSource   @default(ONLINE_QR_CUSTOMER)
  status            OrderStatus   @default(PENDING)
  subtotal          Decimal       @db.Decimal(10, 2)
  serviceCharges    Decimal       @db.Decimal(10, 2)
  tax               Decimal       @db.Decimal(10, 2)
  discount          Decimal       @default(0) @db.Decimal(10, 2)
  total             Decimal       @db.Decimal(10, 2)
  amountPaid        Decimal?      @db.Decimal(10, 2)
  balanceDue        Decimal?      @db.Decimal(10, 2)
  specialNote       String?
  customerName      String?
  customerPhone     String?
  waiterName        String?
  paymentStatus     PaymentStatus @default(UNPAID)
  paymentMethod     PaymentMethod?
  paidAt            DateTime?
  cancelledAt       DateTime?
  cancellationReason String?
  printedKitchenAt  DateTime?
  printedBillAt     DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  items             OrderItem[]
  waiterRequests    WaiterRequest[]
  feedback          Feedback[]

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId, status, createdAt])
  @@index([restaurantId])
  @@index([tableId])
  @@index([createdAt])
}

model OrderItem {
  id                 String    @id @default(cuid())
  orderId            String
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId          String?
  menuItem            MenuItem? @relation(fields: [menuItemId], references: [id])
  itemName            String
  quantity            Int
  unitPrice           Decimal   @db.Decimal(10, 2)
  totalPrice          Decimal   @db.Decimal(10, 2)
  specialInstruction  String?
  addedAfterInitialOrder Boolean @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model WaiterRequest {
  id           String             @id @default(cuid())
  restaurantId String
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      String
  table        RestaurantTable    @relation(fields: [tableId], references: [id])
  orderId      String?
  order        Order?             @relation(fields: [orderId], references: [id])
  type         WaiterRequestType
  status       RequestStatus      @default(PENDING)
  createdAt    DateTime           @default(now())
  resolvedAt   DateTime?
}

model Feedback {
  id           String           @id @default(cuid())
  restaurantId String
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      String?
  table        RestaurantTable? @relation(fields: [tableId], references: [id])
  orderId      String?
  order        Order?           @relation(fields: [orderId], references: [id])
  rating       Int
  comment      String?
  createdAt    DateTime         @default(now())
}

model Subscription {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  planName     String
  monthlyPrice Decimal    @db.Decimal(10, 2)
  status       String
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model BillingInvoice {
  id            String        @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  paymentAccountId String?
  paymentAccount BillingPaymentAccount? @relation(fields: [paymentAccountId], references: [id])
  billingMonth  String
  planName      String
  amount        Decimal       @db.Decimal(10, 2)
  status        InvoiceStatus @default(DUE)
  dueDate       DateTime?
  paidAt        DateTime?
  paymentReference String?
  paymentClaimedAt DateTime?
  paymentClaimMethod String?
  paymentClaimReference String?
  paymentClaimNote String?
  paymentRejectedAt DateTime?
  paymentRejectionNote String?
  paymentConfirmedAt DateTime?
  paymentConfirmedById String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([restaurantId, billingMonth])
  @@index([status, dueDate])
  @@index([paymentClaimedAt])
}

model BillingPaymentAccount {
  id            String      @id @default(cuid())
  restaurantId  String?
  restaurant    Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  label         String
  method        String
  accountTitle  String
  accountNumber String
  bankName      String?
  instructions  String?
  isActive      Boolean     @default(true)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  invoices      BillingInvoice[]

  @@index([restaurantId, isActive])
}

model PlatformLead {
  id                 String     @id @default(cuid())
  restaurantName     String
  contactName        String
  phone              String
  email              String?
  city               String
  expectedTables     Int        @default(20)
  planInterest       String?
  message            String?
  status             LeadStatus @default(NEW)
  source             String     @default("WEBSITE")
  convertedRestaurantId String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([status, createdAt])
}

model ActivityLog {
  id           String      @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  orderId      String?
  action       String
  description  String
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())

  @@index([restaurantId])
  @@index([userId])
  @@index([createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([success, createdAt])
}

model PublicOrderAttempt {
  id                String   @id @default(cuid())
  ipAddress         String
  restaurantId      String?
  restaurant        Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  tableNumber       Int?
  customerSessionId String?
  createdAt         DateTime @default(now())

  @@index([ipAddress, createdAt])
  @@index([restaurantId, tableNumber, createdAt])
  @@index([customerSessionId, createdAt])
}

model AdminPasswordResetOtp {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String    @unique
  otpHash     String
  channel     String
  destination String
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int       @default(0)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([token])
  @@index([expiresAt])
}
